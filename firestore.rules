rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety check: only allow operations on the 'votes' collection
    match /votes/{rollNumber} {
      
      // Allow any student to check if they have already voted
      allow get: if true;

      // Allow creating a new vote record only IF:
      // 1. The document ID (rollNumber) doesn't already exist
      // 2. The rollNumber follows the required pattern
      // 3. The data is marked as active
      allow create: if !exists(/databases/$(database)/documents/votes/$(rollNumber))
                    && rollNumber.matches('^chn24mca-20[0-9]{2}$')
                    && request.resource.data.is_active == true;

      // Restrict updates: normally denied, but could allow special status changes if needed
      // For now, we only allow creating once and reading individually
      allow update: if false;

      // Admin access for the dashboard (List and Delete)
      // In a real app, use request.auth != null. For this specific challenge,
      // we rely on the secret key in the frontend for filtering, but we keep rules tight.
      // NOTE: list is allowed here to facilitate the Admin Dashboard on the free plan.
      allow list: if true; 
      
      // Allow delete for hard reset functionality from admin
      allow delete: if true; 
    }
    
    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
